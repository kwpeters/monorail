{
    "name": "@repo/eslint-config-2",
    "version": "0.0.0",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "echo 'Add dev script here'",
        "build": "tsc --build tsconfig.src.json",
        "test": "tsx ../../node_modules/jasmine/bin/jasmine.js --color --config=./jasmine.json",
        "lint": "eslint .",
        "type-check": "tsc --project tsconfig.json --noEmit",
        "depcheck": "depcheck"
    },
    "exports": {
        "./eslintHelpers": {
            "types": "./src/eslintHelpers.mts",
            "default": "./dist/eslintHelpers.mjs"
        }
    },
    "devDependencies": {
        "@eslint/css": "^0.14.1",
        "@eslint/js": "^10.0.1",
        "@eslint/json": "^1.0.1",
        "@eslint/markdown": "^7.5.1",
        "@repo/typescript-config": "*",
        "@stylistic/eslint-plugin": "^5.9.0",
        "@types/jasmine": "^6.0.0",
        "eslint": "^10.0.1",
        "eslint-config-turbo": "^2.8.13",
        "globals": "^17.3.0",
        "jasmine": "^6.1.0",
        "typescript-eslint": "^8.56.1"
    }
}
