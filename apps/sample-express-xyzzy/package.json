{
    "name": "@repo/sample-express-xyzzy",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "start": "node ./dist/www.mjs",
        "dev": "echo 'Add dev script here'",
        "build-assets": "npx cpx --clean src/public/** ./dist/public",
        "build-tsc": "tsc --build tsconfig.src.json",
        "build": "npm-run-all --parallel build-tsc build-assets",
        "test": "tsx ../../node_modules/jasmine/bin/jasmine.js --color --config=./jasmine.json",
        "lint": "eslint .",
        "type-check": "tsc --project tsconfig.json --noEmit",
        "depcheck": "depcheck"
    },
    "bin": {
        "sample-express-xyzzy": "./dist/index.mjs"
    },
    "dependencies": {
        "@repo/depot": "*",
        "@repo/depot-node": "*",
        "cookie-parser": "~1.4.4",
        "cors": "^2.8.6",
        "express": "^5.2.1",
        "lodash-es": "^4.17.21",
        "morgan": "~1.10.0",
        "winston": "^3.19.0"
    },
    "devDependencies": {
        "@repo/eslint-config": "*",
        "@repo/typescript-config": "*",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jasmine": "^6.0.0",
        "@types/lodash-es": "^4.17.7",
        "@types/morgan": "^1.9.4",
        "eslint": "^10.0.1",
        "jasmine": "^6.1.0"
    }
}
