{
    "name": "@repo/md-tools",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "dev": "echo 'Add dev script here'",
        "build": "npm run build:ts && npm run build:sea",
        "build:ts": "tsc --build tsconfig.src.json",
        "build:sea": "tsx ../build-app-assist/src/index.mts cjsToSeaApp --inputCjsFile ./dist/index.cjs --exeBaseName md-tools",
        "test": "tsx ../../node_modules/jasmine/bin/jasmine.js --color --config=./jasmine.json",
        "lint": "eslint .",
        "type-check": "tsc --project tsconfig.json --noEmit",
        "sync:vscode-css": "tsx ./src/syncVscodeCss.mts",
        "depcheck": "depcheck"
    },
    "bin": {
        "md-tools": "./dist/index.cjs"
    },
    "dependencies": {
        "@repo/depot-node": "*",
        "highlight.js": "^11.11.1",
        "markdown-it": "^14.1.0",
        "markdown-it-anchor": "^9.2.0",
        "markdown-it-deflist": "^3.0.1",
        "markdown-it-emoji": "^3.0.0",
        "markdown-it-footnote": "^4.0.0",
        "markdown-it-task-lists": "^2.1.1",
        "yargs": "^17.7.2"
    },
    "devDependencies": {
        "@repo/build-app-assist": "*",
        "@repo/eslint-config": "*",
        "@repo/typescript-config": "*",
        "@types/jasmine": "^6.0.0",
        "@types/markdown-it-emoji": "^3.0.1",
        "@types/markdown-it-footnote": "^3.0.4",
        "@types/node": "^25.4.0",
        "@types/yargs": "^17.0.24",
        "eslint": "^10.0.1",
        "jasmine": "^6.1.0"
    }
}
