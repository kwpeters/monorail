{
    "name": "@repo/photo-lib",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "dev": "echo 'Add dev script here'",
        "build": "npm run build:ts && npm run build:sea",
        "build:ts": "tsc --build tsconfig.src.json",
        "build:sea": "tsx ../build-app-assist/src/index.mts cjsToSeaApp --inputCjsFile ./dist/index.cjs --exeBaseName photo-lib",
        "test": "tsx ../../node_modules/jasmine/bin/jasmine.js --color --config=./jasmine.json",
        "lint": "eslint .",
        "type-check": "tsc --project tsconfig.json --noEmit",
        "depcheck": "depcheck"
    },
    "bin": {
        "photo-lib": "./dist/index.cjs"
    },
    "dependencies": {
        "@repo/depot": "*",
        "@repo/depot-node": "*",
        "glob": "^13.0.6",
        "lodash-es": "^4.17.21",
        "text-table": "^0.2.0",
        "yargs": "^17.7.2"
    },
    "devDependencies": {
        "@repo/build-app-assist": "*",
        "@repo/eslint-config-2": "*",
        "@repo/typescript-config": "*",
        "@types/jasmine": "^6.0.0",
        "@types/lodash-es": "^4.17.7",
        "@types/node": "^25.4.0",
        "@types/text-table": "^0.2.2",
        "@types/yargs": "^17.0.24",
        "eslint": "^10.0.1",
        "jasmine": "^6.1.0"
    }
}
